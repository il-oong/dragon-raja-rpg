{
  "name": "system-monitor",
  "version": "1.0.19",
  "description": "System Resource Monitor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis",
    "release": "electron-builder --win --publish always",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sys.monitor",
    "productName": "System Monitor",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/electron-updater/**/*",
      "**/node_modules/builder-util-runtime/**/*",
      "**/node_modules/js-yaml/**/*"
    ],
    "compression": "maximum",
    "removePackageScripts": true,
    "electronLanguages": [
      "ko",
      "en-US"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "il-oong",
        "repo": "dragon-raja-rpg"
      }
    ],
    "files": [
      "main.js",
      "index.html",
      "game/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.md",
      "!**/*.ts",
      "!**/README*",
      "!**/LICENSE*",
      "!**/.github/**",
      "!**/test/**",
      "!**/tests/**",
      "!**/spec/**",
      "!**/__tests__/**",
      "!**/docs/**",
      "!**/examples/**",
      "!**/.eslintrc*",
      "!**/.prettierrc*",
      "CHANGELOG.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SystemMonitor-${version}-${ext}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "System Monitor",
      "menuCategory": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "SystemMonitor-Setup-${version}.exe",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "SystemMonitor-Portable-${version}.exe"
    },
    "directories": {
      "output": "dist"
    }
  }
}
