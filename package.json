{
  "name": "system-monitor",
  "version": "1.0.0",
  "description": "System Resource Monitor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sys.monitor",
    "productName": "System Monitor",
    "asar": true,
    "compression": "maximum",
    "removePackageScripts": true,
    "electronLanguages": [
      "ko",
      "en-US"
    ],
    "files": [
      "main.js",
      "index.html",
      "game/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.md",
      "!**/*.ts",
      "!**/README*",
      "!**/LICENSE*",
      "!**/CHANGELOG*",
      "!**/.github/**",
      "!**/test/**",
      "!**/tests/**",
      "!**/spec/**",
      "!**/__tests__/**",
      "!**/docs/**",
      "!**/examples/**",
      "!**/.eslintrc*",
      "!**/.prettierrc*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SystemMonitor.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "SystemMonitor-Setup-${version}.exe"
    },
    "directories": {
      "output": "dist"
    }
  }
}
