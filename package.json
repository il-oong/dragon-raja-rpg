{
  "name": "system-monitor",
  "version": "1.0.0",
  "description": "System Resource Monitor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sys.monitor",
    "productName": "System Monitor",
    "files": [
      "main.js",
      "index.html",
      "game/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SystemMonitor.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "SystemMonitor-Setup-${version}.exe"
    },
    "directories": {
      "output": "dist"
    }
  }
}
